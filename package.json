{
  "name": "memocards",
  "private": true,
  "workspaces": [
    "frontend",
    "memocards-backend",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace memocards-backend",
    "start:frontend": "npm run start --workspace frontend",
    "start:backend": "npm run start --workspace memocards-backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present"
  }
}
