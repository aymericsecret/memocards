{
  "name": "memocards-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:migrate": "dbmate --env-file dbmate.env up",
    "db:rollback": "dbmate --env-file dbmate.env down",
    "db:status": "dbmate --env-file dbmate.env status",
    "import:original-data": "tsx scripts/import-original-data/import-original-data.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "ts-fsrs": "^5.4.1",
    "typedi": "^0.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "dbmate": "^2.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
